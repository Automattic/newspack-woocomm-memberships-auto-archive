{
  "name": "newspack-woocomm-auto-archive",
  "version": "0.1.0",
  "main": "Gruntfile.js",
  "author": "Automattic",
  "devDependencies": {
    "@automattic/calypso-build": "^5.1.0",
    "@babel/core": "^7.6.4",
    "@commitlint/cli": "^8.3.5",
    "@commitlint/config-conventional": "^8.3.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@wordpress/blocks": "^6.7.2",
    "@wordpress/components": "^8.3.2",
    "@wordpress/edit-post": "^3.11.0",
    "@wordpress/eslint-plugin": "^25.3.0",
    "@wordpress/plugins": "^2.10.0",
    "cz-conventional-changelog": "^3.1.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^6.10.0",
    "eslint-plugin-import": "^2.20.1",
    "eslint-plugin-jsdoc": "^63.0.1",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-react": "^7.19.0",
    "grunt": "~0.4.5",
    "grunt-wp-i18n": "~0.5.0",
    "grunt-wp-readme-to-markdown": "~1.0.0",
    "lint-staged": "^10.0.8",
    "npm-run-all": "^4.1.5",
    "prettier": "https://github.com/Automattic/wp-prettier/releases/download/wp-1.16.4/wp-prettier-1.16.4.tgz",
    "semantic-release": "^19.0.5",
    "semantic-release-version-bump": "^1.4.1",
    "stylelint": "^13.13.1",
    "stylelint-config-prettier": "^8.0.1",
    "stylelint-config-wordpress": "^17.0.0",
    "stylelint-prettier": "^1.1.2",
    "webpack": "^4.41.2",
    "webpack-cli": "^3.3.9"
  },
  "scripts": {
    "cm": "git-cz",
    "semantic-release": "semantic-release",
    "start": "npm run dev",
    "dev": "NODE_OPTIONS=--openssl-legacy-provider calypso-build --watch --config='./webpack.config.js'",
    "lint": "npm-run-all --parallel lint:*",
    "lint:js": "eslint --ext .js,.jsx src",
    "format:js": "prettier 'src/**/*.{js,jsx}' --write",
    "lint:scss": "stylelint \"**/*.scss\" --syntax scss",
    "format:scss": "prettier --write 'src/**/*.scss'",
    "lint:scss:staged": "stylelint --syntax scss",
    "build": "NODE_OPTIONS=--openssl-legacy-provider calypso-build --config='./webpack.config.js'",
    "clean": "rm -rf dist/",
    "release:archive": "mkdir -p release && zip -r release/newspack-woocomm-memberships-auto-archive.zip . -x node_modules/\\* .git/\\* .github/\\* .gitignore .DS_Store",
    "release": "npm run build && npm run semantic-release"
  },
  "lint-staged": {
    "*.scss": "npm run lint:scss:staged"
  },
  "overrides": {
    "@babel/traverse": "7.29.7",
    "cipher-base": "1.0.5",
    "elliptic": "6.6.1",
    "form-data": "2.5.5",
    "getobject": "1.1.1",
    "handlebars": "4.7.9",
    "json-schema": "0.4.0",
    "loader-utils": "1.4.2",
    "lodash": "4.17.21",
    "minimist": "1.2.8",
    "pbkdf2": "3.1.3",
    "sha.js": "2.4.12",
    "shell-quote": "1.7.3",
    "underscore": "1.13.8"
  },
  "release": {
    "branches": [
      "release"
    ],
    "prepare": [
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "semantic-release-version-bump",
        {
          "files": "newspack-woocomm-memberships-auto-archive.php",
          "callback": "npm run release:archive"
        }
      ],
      {
        "path": "@semantic-release/git",
        "assets": [
          "newspack-woocomm-memberships-auto-archive.php",
          "package.json",
          "package-lock.json",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "semantic-release-version-bump",
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "./release/newspack-woocomm-memberships-auto-archive.zip",
              "label": "newspack-woocomm-memberships-auto-archive.zip"
            }
          ]
        }
      ]
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@wordpress/api-fetch": "^3.11.0",
    "@wordpress/block-editor": "^3.7.5",
    "@wordpress/compose": "^3.11.0",
    "@wordpress/data": "^4.14.1",
    "@wordpress/dom-ready": "^2.10.0",
    "@wordpress/element": "^2.11.0",
    "@wordpress/i18n": "^3.9.0",
    "newspack-components": "^1.0.5",
    "qs": "^6.9.1"
  }
}
